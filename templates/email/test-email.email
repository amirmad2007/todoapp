{% block subject %}
تأیید ایمیل - {{ site_name }}
{% endblock %}

{% block html %}
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Arial, sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh;">
    <table width="100%" cellpadding="0" cellspacing="0" style="padding: 40px 20px;">
        <tr>
            <td align="center">
                <table width="600" cellpadding="0" cellspacing="0" style="background-color: #ffffff; border-radius: 20px; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.3);">
                    
                    <!-- Header with Icon -->
                    <tr>
                        <td style="padding: 50px 30px 30px; text-align: center;">
                            <div style="width: 80px; height: 80px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);">
                                <span style="font-size: 40px; color: #ffffff;">✉️</span>
                            </div>
                            <h1 style="color: #2d3748; margin: 0 0 10px; font-size: 32px; font-weight: 700;">تأیید ایمیل</h1>
                            <p style="color: #718096; font-size: 16px; margin: 0;">سلام {{ user.first_name }} عزیز!</p>
                        </td>
                    </tr>
                    
                    <!-- Content -->
                    <tr>
                        <td style="padding: 0 40px 40px;">
                            <p style="color: #4a5568; font-size: 16px; line-height: 1.8; margin-bottom: 30px; text-align: center;">
                                از اینکه به <strong style="color: #667eea;">{{ site_name }}</strong> پیوستید خوشحالیم! 🎉<br>
                                برای فعال‌سازی حساب کاربری، لطفاً ایمیل خود را تأیید کنید.
                            </p>
                            
                            <!-- Verification Box -->
                            <div style="background: linear-gradient(135deg, #f7fafc 0%, #edf2f7 100%); padding: 30px; border-radius: 15px; margin: 30px 0; border: 2px solid #e2e8f0;">
                                <p style="color: #2d3748; font-size: 14px; margin: 0 0 20px; text-align: center; font-weight: 600;">
                                    🔐 برای تأیید هویت، روی دکمه زیر کلیک کنید:
                                </p>
                                
                                <!-- Button -->
                                <table width="100%" cellpadding="0" cellspacing="0">
                                    <tr>
                                        <td align="center">
                                            <a href="http://localhost:8000/accounts/api/v1/email-verification/{{access_token}}" style="display: inline-block; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #ffffff; padding: 18px 50px; text-decoration: none; border-radius: 50px; font-size: 18px; font-weight: bold; box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4); transition: all 0.3s;">
                                                ✓ تأیید ایمیل
                                            </a>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            
                            <!-- Security Notice -->
                            <div style="background-color: #fff5f5; border-right: 4px solid #fc8181; padding: 20px; border-radius: 10px; margin-top: 30px;">
                                <p style="color: #742a2a; font-size: 14px; line-height: 1.6; margin: 0;">
                                    <strong>⚠️ توجه امنیتی:</strong><br>
                                    اگر شما این درخواست را ثبت نکرده‌اید، لطفاً این ایمیل را نادیده بگیرید و حساب کاربری شما ایمن خواهد ماند.
                                </p>
                            </div>
                            
                            <!-- Alternative Link -->
                            <p style="color: #a0aec0; font-size: 13px; line-height: 1.6; margin-top: 30px; text-align: center; padding-top: 20px; border-top: 1px solid #e2e8f0;">
                                اگر دکمه کار نمی‌کند، لینک زیر را کپی کرده و در مرورگر باز کنید:<br>
                                <span style="color: #667eea; word-break: break-all; font-size: 12px;">http://localhost:8000/accounts/api/v1/email-verification/{{access_token}}</span>
                            </p>
                        </td>
                    </tr>
                    
                    <!-- Footer -->
                    <tr>
                        <td style="background: linear-gradient(135deg, #f7fafc 0%, #edf2f7 100%); padding: 30px; text-align: center; border-top: 1px solid #e2e8f0;">
                            <p style="color: #718096; font-size: 14px; margin: 0 0 10px;">
                                با تشکر از اعتماد شما 💙
                            </p>
                            <p style="color: #a0aec0; font-size: 12px; margin: 0;">
                                © 2026 {{ site_name }}. تمامی حقوق محفوظ است.
                            </p>
                        </td>
                    </tr>
                    
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
{% endblock %}

{% block plain %}
✉️ تأیید ایمیل - {{ site_name }}

سلام {{ user.first_name }} عزیز!

از اینکه به {{ site_name }} پیوستید خوشحالیم! 🎉

برای فعال‌سازی حساب کاربری، لطفاً ایمیل خود را تأیید کنید.

🔐 لینک تأیید:
http://localhost:8000/accounts/api/v1/email-verification/{{access_token}}

⚠️ توجه امنیتی:
اگر شما این درخواست را ثبت نکرده‌اید، لطفاً این ایمیل را نادیده بگیرید و حساب کاربری شما ایمن خواهد ماند.

---
با تشکر از اعتماد شما 💙
© 2026 {{ site_name }}. تمامی حقوق محفوظ است.
{% endblock %}
